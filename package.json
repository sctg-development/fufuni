{
  "name": "fufuni",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/merchant",
    "apps/merchant/admin",
    "apps/merchant/example",
    "apps/client",
    "apps/cloudflare-worker"
  ],
  "devDependencies": {
    "fast-glob": "^3.3.3",
    "turbo": "^2.8.14"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:env": "turbo run dev:env --parallel",
    "build": "turbo run build",
    "build:env": "bash -c 'turbo run build:env -- \"$@\"' --",
    "build:client:env": "bash -c 'npm --workspace=apps/client run build:env \"$@\"' --",
    "preview:env": "bash -c '(cd apps/merchant && npm run preview:env) & (cd apps/client && npm run preview:env -- \"$@\") && wait' --",
    "start": "npm run dev",
    "export:llms": "tsx scripts/export-code-for-lllm.ts",
    "clean:seed:start": "bash scripts/clean-seed-start.sh",
    "stripe:listen": "bash -c 'source .env && stripe --api-key $STRIPE_SECRET_KEY listen --load-from-webhooks-api --forward-to http://localhost:8787'"
  }
}
